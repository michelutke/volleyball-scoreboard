{
	"name": "scoring",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"licenses": "license-checker --production --json --out static/licenses.json",
		"build": "npm run licenses && vite build",
		"preview": "vite preview",
		"prepare": "husky",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test": "vitest run",
		"test:watch": "vitest"
	},
	"devDependencies": {
		"@sveltejs/kit": "^2.55.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/vite": "^4.2.2",
		"@types/node": "^25.5.0",
		"@types/qrcode": "^1.5.5",
		"drizzle-kit": "^0.31.10",
		"husky": "^9.1.7",
		"license-checker": "^25.0.1",
		"svelte": "^5.55.0",
		"svelte-check": "^4.4.5",
		"tailwindcss": "^4.2.1",
		"typescript": "^5.9.3",
		"vite": "^8.0.2",
		"vitest": "^4.1.2"
	},
	"dependencies": {
		"@auth/sveltekit": "^1.11.1",
		"@fontsource-variable/inter": "^5.2.8",
		"@fontsource/montserrat": "^5.2.8",
		"@stripe/stripe-js": "^8.11.0",
		"@sveltejs/adapter-node": "^5.5.4",
		"drizzle-orm": "^0.45.1",
		"lru-cache": "^11.2.7",
		"lucide-svelte": "^1.0.1",
		"motion": "^12.38.0",
		"postgres": "^3.4.8",
		"qrcode": "^1.5.4",
		"stripe": "^20.4.1",
		"zod": "^4.3.6"
	}
}
