DATABASE_URL=postgres://scoring:scoring@localhost:5432/scoring

# Public URL of the app — required in production (SvelteKit CSRF protection)
# Must match the domain your app is served from, no trailing slash
# ORIGIN=https://your-domain.com

# Keycloak OIDC
KEYCLOAK_CLIENT_ID=scoring-app
# Dev default from keycloak/realm.json — regenerate for production
KEYCLOAK_CLIENT_SECRET=REPLACE_ME
KEYCLOAK_ISSUER=http://localhost:8080/realms/scoring

# Auth.js session encryption (generate: openssl rand -base64 32)
AUTH_SECRET=

# AES-256-GCM key for encrypted DB fields (generate: openssl rand -hex 32)
ENCRYPTION_KEY=

# Keycloak Admin API (only needed for /admin/users user management)
KEYCLOAK_ADMIN_URL=http://localhost:8080
KEYCLOAK_ADMIN_CLIENT_ID=scoring-app
KEYCLOAK_ADMIN_CLIENT_SECRET=
KEYCLOAK_REALM=scoring
